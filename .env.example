# Telegram bot
TG_BOT_TOKEN=
TG_CHAT_ID=

# GitHub push target for the archive repository.
# Use a token with write access to maxlixiang/save_zhihu_activity.
GITHUB_TOKEN=
GITHUB_REPOSITORY=maxlixiang/save_zhihu_activity

# Container paths. docker-compose.yml maps these to /root/zhihu_data on the VPS.
ARCHIVE_ROOT_DIR=/app/save_zhihu_activity
GITHUB_REPO_PATH=/app/save_zhihu_activity
ZH_DB_FILE=/app/zhihu_articles.db
